{
  "name": "logitcat",
  "displayName": "logitcat",
  "description": "Real-time log parsing and alerting inside VS Code",
  "version": "0.1.0",
  "publisher": "sammug",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Debuggers", "Other"],
  "icon": "media/icon.png",
  "activationEvents": ["onStartupFinished"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sammug/logitcat-vscode"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "logitcat.start",         "title": "Start",          "category": "logitcat", "icon": "$(play)" },
      { "command": "logitcat.stop",          "title": "Stop",           "category": "logitcat", "icon": "$(stop)" },
      { "command": "logitcat.openDashboard", "title": "Open Dashboard", "category": "logitcat", "icon": "$(browser)" },
      { "command": "logitcat.clearAlerts",   "title": "Clear Alerts",   "category": "logitcat", "icon": "$(trash)" },
      { "command": "logitcat.copyMessage",   "title": "Copy Message",   "category": "logitcat" },
      { "command": "logitcat.copyRaw",        "title": "Copy Raw Line",  "category": "logitcat" },
      { "command": "logitcat.showDetail",    "title": "View Details",   "category": "logitcat", "icon": "$(open-preview)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "logitcat",
          "title": "logitcat",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "logitcat": [
        { "id": "logitcat.alerts", "name": "Alerts", "icon": "media/icon.svg" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "logitcat.start",         "when": "view == logitcat.alerts", "group": "navigation@1" },
        { "command": "logitcat.stop",          "when": "view == logitcat.alerts", "group": "navigation@2" },
        { "command": "logitcat.openDashboard", "when": "view == logitcat.alerts", "group": "navigation@3" },
        { "command": "logitcat.clearAlerts",   "when": "view == logitcat.alerts", "group": "navigation@4" }
      ],
      "view/item/context": [
        { "command": "logitcat.showDetail",  "when": "viewItem == alert", "group": "logitcat@1" },
        { "command": "logitcat.copyMessage", "when": "viewItem == alert", "group": "logitcat@2" },
        { "command": "logitcat.copyRaw",     "when": "viewItem == alert", "group": "logitcat@3" }
      ]
    },
    "configuration": {
      "title": "logitcat",
      "properties": {
        "logitcat.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the logitcat binary (leave empty to auto-detect)"
        },
        "logitcat.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to logitcat config .ini file"
        },
        "logitcat.dashboardPort": {
          "type": "number",
          "default": 9090,
          "description": "Port for the logitcat web dashboard"
        },
        "logitcat.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start logitcat when a workspace is opened"
        },
        "logitcat.maxAlerts": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of alerts to keep in the panel"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch":   "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node":   "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript":    "^5.3.0"
  }
}
